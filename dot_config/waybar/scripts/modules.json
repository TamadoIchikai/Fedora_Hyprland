{
  "mpris": {
    "format": "[ ´Çü  {status_icon} | {dynamic} ]",
    "format-paused": "[ ´Çü  {status_icon} | {dynamic} ]",
    "format-stopped": "[ ´Çü  {status_icon} | No media playing ]",
    "format-disconnected": "[ ´Çü  ´üì | No media playing ]",
    "interval": 1,
    "status-icons": {
      "playing": "´öÇ",
      "paused": "´èî",
      "stopped": "´üì"
    },
    "dynamic-order": ["artist"]
  },
  "custom/mpris": {
    "exec": "~/.config/waybar/scripts/mpris-fallback.sh",
    "interval": 1
  },

  "group/mpris": {
    "orientation": "horizontal",
    "modules": ["mpris", "custom/mpris"]
  },

  "custom/appmenu": {
    "format": "´îï",
    "tooltip-format": "Fedora",
    "on-click": "fuzzel-scale.sh",
    "on-click-right": "fuzzel-powermenu.sh"
  },

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "¾▒à½",
      "none": "¾░éÜ",
      "dnd-notification": "¾▒à½",
      "dnd-none": "¾░éø",
      "inhibited-notification": "´éó",
      "inhibited-none": "´éó",
      "dnd-inhibited-notification": "´éó",
      "dnd-inhibited-none": "´éó"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "custom/timer": {
	  "exec": "~/.config/waybar/scripts/timer_multi_monitor.sh",
	  "return-type": "json",
	  "format": "{}",
	  "on-click": "~/.config/waybar/scripts/timer_multi_monitor.sh click",
	  "on-click-right": "~/.config/waybar/scripts/timer_multi_monitor.sh right",
	  "on-click-middle": "~/.config/waybar/scripts/timer_multi_monitor.sh middle",
	  "on-scroll-up": "~/.config/waybar/scripts/timer_multi_monitor.sh down",
	  "on-scroll-down": "~/.config/waybar/scripts/timer_multi_monitor.sh up",
	  "tooltip": true,
	  "escape": true
  },

  "hyprland/scratchpad": {
    "format": "{icon} {count}",
    "show-empty": false,
    "format-icons": ["", "´ïÆ"],
    "tooltip": true,
    "tooltip-format": "{app}: {title}"
  },

  
  "tray": {
    "icon-size": 24,
    "spacing": 10,
    "show-passive-items": true
  },
  
  "clock": {
    "format": "¾░àÉ  {:%a %d %b %H:%M}",
    "tooltip-format": "<tt><big>{calendar}</big></tt>",
    "calendar": {
		"mode"          : "month",
		"mode-mon-col"  : 3,
		"weeks-pos"     : "right",
		"on-scroll"     : 1,
		"on-click-right": "mode",
		"format": {
			"months":     "<span color='#ffead3'><b>{}</b></span>",
			"days":       "<span color='#ecc6d9'><b>{}</b></span>",
			"weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
			"weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
			"today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
		}
	},
	"actions": {
		"on-click-right": "mode",
		"on-click-forward": "tz_up",
		"on-click-backward": "tz_down",
		"on-scroll-up": "shift_up",
		"on-scroll-down": "shift_down"
	}
  },
  
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "¾▒êæ {capacity}%",
    "format-charging": "{icon} {capacity}%",
    "format-plugged": "´çª {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░óƒ", "¾░éå", "¾░éê", "¾░ó×", "¾▒êæ"]
  }

}
