{
  "cpu": {
    "interval": 0.5,
    "format": "<tt><small>CPU</small></tt> {icon}",
    "format-icons": ["ѓАІ", "ѓАЊ", "ѓАЊ", "ѓАЊ ", "ѓАЊЁ", "ѓАЊЂ", "ѓАЊЃ", "ѓАЊЄ", "ѓАЊЅ"],
    "states": {
	    "good": 0,
	    "warning": 70,
	    "critical": 90
	  },
    "on-click": "foot btop &",
    "on-click-right": "foot gdu -d"
  },

  "memory": {
    "interval": 1,
    "format": "<tt><small>RAM</small></tt> {icon}",
    "format-icons": ["ѓАІ", "ѓАЊ", "ѓАЊ", "ѓАЊ ", "ѓАЊЁ", "ѓАЊЂ", "ѓАЊЃ", "ѓАЊЄ", "ѓАЊЅ"],
    "max-length": 10,
    "states": {
	    "good": 0,
	    "warning": 60,
	    "critical": 85
	  },
    "on-click": "foot btop &",
    "on-click-right": "foot gdu -d"
  },

  "group/hardware": {
    "orientation": "horizontal",
    "modules": ["cpu", "memory"]
  }
}
